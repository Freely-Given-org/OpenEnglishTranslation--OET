\li1
\v 13 666 descendantsВҰ217491 of AdonikamВҰ217492,
\li1
\v 14 2,056 descendantsВҰ217499 of BigvaiВҰ217500,
\li1
\v 15 454 descendantsВҰ217506 of AdinВҰ217507,
\li1
\v 16 98 descendants of AterВҰ217516, \add who descended\add* from HezkiyyahВҰ217517,
\li1
\v 17 323 descendantsВҰ217522 of BetsaiВҰ217523,
\li1
\v 18 112 descendantsВҰ217530 of YorahВҰ217531,
